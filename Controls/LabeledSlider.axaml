<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PenDynamicsLab.Controls.LabeledSlider">
    <StackPanel Spacing="2">
        <DockPanel>
            <TextBlock x:Name="LabelText" FontWeight="Bold" FontSize="10" Foreground="#555555" />
            <Panel HorizontalAlignment="Right">
                <TextBlock x:Name="ValueText" FontSize="11" Foreground="#333333"
                           Cursor="Ibeam" />
                <TextBox x:Name="ValueEdit" IsVisible="False" Width="52" FontSize="11"
                         Padding="2,0" MinHeight="0" />
            </Panel>
        </DockPanel>
        <Slider x:Name="MainSlider" SmallChange="0.01" />
    </StackPanel>
</UserControl>
