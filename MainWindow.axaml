<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:PenDynamicsLab.Controls"
        x:Class="PenDynamicsLab.MainWindow"
        Title="PenDynamicsLab" Width="1500" Height="900"
        FontFamily="Segoe UI" FontSize="12">
    <Window.Styles>
        <!-- Force a single font size across every control. FluentTheme defaults don't
             always inherit from the Window-level FontSize. -->
        <Style Selector="TextBlock">    <Setter Property="FontSize" Value="12" /></Style>
        <Style Selector="TextBox">      <Setter Property="FontSize" Value="12" /></Style>
        <Style Selector="Button">       <Setter Property="FontSize" Value="12" /></Style>
        <Style Selector="ComboBox">     <Setter Property="FontSize" Value="12" /></Style>
        <Style Selector="ComboBoxItem"> <Setter Property="FontSize" Value="12" /></Style>
        <Style Selector="CheckBox">     <Setter Property="FontSize" Value="12" /></Style>
        <Style Selector="RadioButton">  <Setter Property="FontSize" Value="12" /></Style>
        <Style Selector="MenuItem">     <Setter Property="FontSize" Value="12" /></Style>
        <Style Selector="Slider">       <Setter Property="FontSize" Value="12" /></Style>

        <!-- Shrink the slider thumb (the draggable knob). FluentTheme defaults to ~16px. -->
        <Style Selector="Slider:horizontal /template/ Thumb">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
        </Style>
    </Window.Styles>
    <DockPanel>
        <!-- Driver warning banner (dismissible) -->
        <Border DockPanel.Dock="Top" x:Name="DriverWarningBanner"
                Background="#FFF8E1" BorderBrush="#E0C77A" BorderThickness="0,0,0,1"
                Padding="10,6">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="✕" Width="24" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        Click="DismissDriverWarning_Click" />
                <TextBlock VerticalAlignment="Center" Foreground="#704C00"
                           TextWrapping="Wrap">
                    Tip: set your tablet driver's pressure curve to default (linear) so this app
                    sees raw pen input — otherwise you're tuning a curve on top of a curve.
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Top ribbon: pen telemetry + API selector -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="8,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                <!-- APP -->
                <StackPanel>
                    <TextBlock Text="APP" FontWeight="Bold"                               Foreground="#555555" Margin="0,0,0,4" />
                    <ComboBox x:Name="ApiCombo" Width="120" Height="28" />
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD" />

                <!-- PEN -->
                <StackPanel Width="80">
                    <TextBlock Text="PEN" FontWeight="Bold"                               Foreground="#555555" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse x:Name="ProximityDot" Width="8" Height="8" Fill="Gray" />
                        <TextBlock x:Name="ProximityLabel" Text="Out" Foreground="#888888" />
                    </StackPanel>
                    <TextBlock x:Name="CursorLabel" Text="Cursor: --" />
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD" />

                <!-- POSITION -->
                <StackPanel Width="160">
                    <TextBlock Text="POSITION" FontWeight="Bold"                               Foreground="#555555" Margin="0,0,0,4" />
                    <TextBlock x:Name="RawPosLabel" Text="Raw: --,--" />
                    <TextBlock x:Name="ScreenPosLabel" Text="Screen: --,--" />
                    <TextBlock x:Name="AppPosLabel" Text="App: --,--" />
                    <TextBlock x:Name="CanvasPosLabel" Text="Canvas: --,--" />
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD" />

                <!-- PRESSURE -->
                <StackPanel Width="90">
                    <TextBlock Text="PRESSURE" FontWeight="Bold"                               Foreground="#555555" Margin="0,0,0,4" />
                    <TextBlock x:Name="RawPressureLabel" Text="Raw: --" />
                    <TextBlock x:Name="NormPressureLabel" Text="Norm: --" />
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD" />

                <!-- ORIENTATION -->
                <StackPanel Width="100">
                    <TextBlock Text="ORIENTATION" FontWeight="Bold"                               Foreground="#555555" Margin="0,0,0,4" />
                    <TextBlock x:Name="AzimuthLabel" Text="Azimuth: --" />
                    <TextBlock x:Name="AltitudeLabel" Text="Altitude: --" />
                    <TextBlock x:Name="TwistLabel" Text="Twist: --" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body: left = curve chart + controls, right = drawing canvases -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LeftPanel: chart + controls -->
            <DockPanel x:Name="LeftPanel" Grid.Column="0" Background="#FAFAFA">
                <DockPanel DockPanel.Dock="Top">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right"
                                Margin="0,4,8,0" Spacing="6">
                        <Button Content="Save chart..." Padding="6,2"
                                Click="SaveCurveChart_Click" />
                    </StackPanel>
                    <controls:PressureChartControl x:Name="PressureChart" Margin="8,0,8,0" />
                </DockPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,4,12,12" Spacing="10">
                        <!-- Curve type -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="CURVE TYPE" FontWeight="Bold" Foreground="#555555" />
                            <ComboBox x:Name="CurveTypeCombo" HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <!-- Bezier toolbar (visible only for Bezier curve type) -->
                        <StackPanel x:Name="BezierToolbar" Spacing="4" IsVisible="False">
                            <TextBlock Text="BEZIER POINTS" FontWeight="Bold" Foreground="#555555" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button x:Name="BezierAddButton" Content="Add point" Click="BezierAdd_Click" />
                                <Button x:Name="BezierRemoveButton" Content="Remove point" Click="BezierRemove_Click" />
                                <TextBlock x:Name="BezierCountLabel" VerticalAlignment="Center"
                                           Foreground="#666666" />
                            </StackPanel>
                            <TextBlock Text="Right-click in plot to add or remove."
                                       Foreground="#888888" />
                            <DockPanel>
                                <TextBlock Text="Preset:" VerticalAlignment="Center"                                           Margin="0,0,6,0" />
                                <ComboBox x:Name="BezierPresetCombo" HorizontalAlignment="Stretch"
                                          PlaceholderText="Choose preset..." />
                            </DockPanel>
                        </StackPanel>

                        <controls:LabeledSlider x:Name="SoftnessSlider" Label="SOFTNESS"
                                                Minimum="-0.9" Maximum="0.9" Value="0" DefaultValue="0" />

                        <controls:LabeledSlider x:Name="InputMinSlider" Label="INPUT MIN"
                                                Minimum="0" Maximum="1" Value="0" DefaultValue="0" />
                        <controls:LabeledSlider x:Name="InputMaxSlider" Label="INPUT MAX"
                                                Minimum="0" Maximum="1" Value="1" DefaultValue="1" />
                        <controls:LabeledSlider x:Name="OutputMinSlider" Label="OUTPUT MIN"
                                                Minimum="0" Maximum="1" Value="0" DefaultValue="0" />
                        <controls:LabeledSlider x:Name="OutputMaxSlider" Label="OUTPUT MAX"
                                                Minimum="0" Maximum="1" Value="1" DefaultValue="1" />

                        <!-- Min approach -->
                        <StackPanel x:Name="MinApproachPanel" Spacing="4">
                            <TextBlock Text="MIN APPROACH" FontWeight="Bold" Foreground="#555555" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <RadioButton x:Name="MinApproachClampRadio" GroupName="MinApproach"
                                             Content="Clamp" IsChecked="True" />
                                <RadioButton x:Name="MinApproachCutRadio" GroupName="MinApproach"
                                             Content="Cut" />
                            </StackPanel>
                        </StackPanel>

                        <controls:LabeledSlider x:Name="FlatLevelSlider" Label="FLAT LEVEL"
                                                Minimum="0" Maximum="1" Value="0.5" DefaultValue="0.5" />

                        <!-- Smoothing section -->
                        <Rectangle Height="1" Fill="#DDDDDD" Margin="0,6,0,0" />
                        <TextBlock Text="SMOOTHING" FontWeight="Bold" Foreground="#555555" />

                        <controls:LabeledSlider x:Name="PressureEmaSlider" Label="PRESSURE EMA"
                                                Minimum="0" Maximum="0.99" Value="0" DefaultValue="0" />
                        <controls:LabeledSlider x:Name="PositionEmaSlider" Label="POSITION EMA"
                                                Minimum="0" Maximum="0.99" Value="0" DefaultValue="0" />
                        <StackPanel Spacing="2">
                            <TextBlock Text="SMOOTHING ORDER" FontWeight="Bold" Foreground="#555555" />
                            <ComboBox x:Name="SmoothingOrderCombo" HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <!-- Presets section -->
                        <Rectangle Height="1" Fill="#DDDDDD" Margin="0,6,0,0" />
                        <TextBlock Text="USER PRESETS" FontWeight="Bold" Foreground="#555555" />

                        <DockPanel>
                            <Button DockPanel.Dock="Right" x:Name="PresetSaveButton" Content="Save"
                                    Margin="6,0,0,0" Click="PresetSave_Click" />
                            <TextBox x:Name="PresetNameInput" HorizontalAlignment="Stretch"
                                     Watermark="Preset name..." />
                        </DockPanel>
                        <StackPanel x:Name="PresetList" Spacing="2" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <!-- Splitter -->
            <Rectangle Grid.Column="1" Fill="#CCCCCC" />

            <!-- Right panel: tabbed views. Each tab is its own workflow. -->
            <DockPanel x:Name="CanvasArea" Grid.Column="2" Background="#F5F5F0">
                <controls:BrushRibbon DockPanel.Dock="Top" x:Name="BrushRibbon" />

                <TabControl x:Name="RightTabs" Padding="0">
                    <TabItem x:Name="StrokeTab" Header="Stroke">
                        <controls:StrokeCanvasView x:Name="StrokeView" Header="Pressure processing: ON" />
                    </TabItem>

                    <TabItem x:Name="StrokeCompareTab" Header="Stroke compare">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="1" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <controls:StrokeCanvasView Grid.Row="0" x:Name="CompareProcessedView"
                                                       Header="Pressure processing: ON" />
                            <Rectangle Grid.Row="1" Fill="#CCCCCC" />
                            <controls:StrokeCanvasView Grid.Row="2" x:Name="CompareRawView"
                                                       Header="Pressure processing: OFF" />
                        </Grid>
                    </TabItem>

                <TabItem Header="Pressure response">
                    <DockPanel Margin="12">
                        <StackPanel DockPanel.Dock="Top" Spacing="8">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" x:Name="ResponseClearButton" Content="Clear"
                                        IsEnabled="False" Margin="6,0,0,0" Click="ResponseClear_Click" />
                                <ComboBox x:Name="ResponseDataCombo" HorizontalAlignment="Stretch"
                                          PlaceholderText="Select data..." />
                            </DockPanel>
                            <CheckBox x:Name="ResponseShowCurveEffectCheck" Content="Show effect of curve"
                                      IsChecked="True" />
                            <TextBlock x:Name="ResponseInfoLabel" Foreground="#888888" />
                        </StackPanel>
                        <controls:PressureResponseChartControl x:Name="ResponseChart" />
                    </DockPanel>
                </TabItem>
                </TabControl>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
