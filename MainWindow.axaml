<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:PenDynamicsLab.Controls"
        x:Class="PenDynamicsLab.MainWindow"
        Title="PenDynamicsLab" Width="1400" Height="800">
    <DockPanel>
        <!-- Ribbon -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="8,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                <!-- APP -->
                <StackPanel>
                    <TextBlock Text="APP" FontWeight="Bold" FontSize="10"
                               Foreground="#555555" Margin="0,0,0,4" />
                    <ComboBox x:Name="ApiCombo" Width="120" Height="28" />
                    <Button Content="Clear" Height="28" Width="60" Margin="0,4,0,0"
                            Click="Clear_Click" />
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD" />

                <!-- BRUSH -->
                <StackPanel>
                    <TextBlock Text="BRUSH" FontWeight="Bold" FontSize="10"
                               Foreground="#555555" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Size" VerticalAlignment="Center" />
                        <TextBlock x:Name="BrushSizeLabel" Text="6 px"
                                   VerticalAlignment="Center" Width="35" />
                    </StackPanel>
                    <Slider x:Name="BrushSizeSlider" Width="100" Minimum="1" Maximum="50"
                            Value="6" IsSnapToTickEnabled="True" TickFrequency="1" />
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD" />

                <!-- PEN -->
                <StackPanel Width="80">
                    <TextBlock Text="PEN" FontWeight="Bold" FontSize="10"
                               Foreground="#555555" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse x:Name="ProximityDot" Width="8" Height="8" Fill="Gray" />
                        <TextBlock x:Name="ProximityLabel" Text="Out" Foreground="#888888" />
                    </StackPanel>
                    <TextBlock x:Name="CursorLabel" Text="Cursor: --" FontSize="11" />
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD" />

                <!-- POSITION -->
                <StackPanel Width="160">
                    <TextBlock Text="POSITION" FontWeight="Bold" FontSize="10"
                               Foreground="#555555" Margin="0,0,0,4" />
                    <TextBlock x:Name="RawPosLabel" Text="Raw: --,--" FontSize="11" />
                    <TextBlock x:Name="ScreenPosLabel" Text="Screen: --,--" FontSize="11" />
                    <TextBlock x:Name="AppPosLabel" Text="App: --,--" FontSize="11" />
                    <TextBlock x:Name="CanvasPosLabel" Text="Canvas: --,--" FontSize="11" />
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD" />

                <!-- PRESSURE -->
                <StackPanel Width="90">
                    <TextBlock Text="PRESSURE" FontWeight="Bold" FontSize="10"
                               Foreground="#555555" Margin="0,0,0,4" />
                    <TextBlock x:Name="RawPressureLabel" Text="Raw: --" FontSize="11" />
                    <TextBlock x:Name="NormPressureLabel" Text="Norm: --" FontSize="11" />
                </StackPanel>
                <Rectangle Width="1" Fill="#DDDDDD" />

                <!-- ORIENTATION -->
                <StackPanel Width="100">
                    <TextBlock Text="ORIENTATION" FontWeight="Bold" FontSize="10"
                               Foreground="#555555" Margin="0,0,0,4" />
                    <TextBlock x:Name="AzimuthLabel" Text="Azimuth: --" FontSize="11" />
                    <TextBlock x:Name="AltitudeLabel" Text="Altitude: --" FontSize="11" />
                    <TextBlock x:Name="TwistLabel" Text="Twist: --" FontSize="11" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body: left = curve chart + controls, right = drawing canvas -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="480" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: curve chart on top, scrollable controls below -->
            <DockPanel Grid.Column="0" Background="#FAFAFA">
                <controls:PressureChartControl x:Name="PressureChart"
                                               DockPanel.Dock="Top"
                                               Height="320" Margin="8" />
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,4,12,12" Spacing="10">
                        <!-- Curve type -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="CURVE TYPE" FontWeight="Bold" FontSize="10" Foreground="#555555" />
                            <ComboBox x:Name="CurveTypeCombo" Width="180" />
                        </StackPanel>

                        <!-- Softness -->
                        <StackPanel Spacing="2">
                            <DockPanel>
                                <TextBlock Text="SOFTNESS" FontWeight="Bold" FontSize="10" Foreground="#555555" />
                                <TextBlock x:Name="SoftnessLabel" FontSize="11" Foreground="#333333"
                                           HorizontalAlignment="Right" />
                            </DockPanel>
                            <Slider x:Name="SoftnessSlider" Minimum="-0.9" Maximum="0.9"
                                    Value="0" SmallChange="0.01" />
                        </StackPanel>

                        <!-- Input range -->
                        <StackPanel Spacing="2">
                            <DockPanel>
                                <TextBlock Text="INPUT MIN" FontWeight="Bold" FontSize="10" Foreground="#555555" />
                                <TextBlock x:Name="InputMinLabel" FontSize="11" HorizontalAlignment="Right" />
                            </DockPanel>
                            <Slider x:Name="InputMinSlider" Minimum="0" Maximum="1" Value="0" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <DockPanel>
                                <TextBlock Text="INPUT MAX" FontWeight="Bold" FontSize="10" Foreground="#555555" />
                                <TextBlock x:Name="InputMaxLabel" FontSize="11" HorizontalAlignment="Right" />
                            </DockPanel>
                            <Slider x:Name="InputMaxSlider" Minimum="0" Maximum="1" Value="1" />
                        </StackPanel>

                        <!-- Output range -->
                        <StackPanel Spacing="2">
                            <DockPanel>
                                <TextBlock Text="OUTPUT MIN" FontWeight="Bold" FontSize="10" Foreground="#555555" />
                                <TextBlock x:Name="OutputMinLabel" FontSize="11" HorizontalAlignment="Right" />
                            </DockPanel>
                            <Slider x:Name="OutputMinSlider" Minimum="0" Maximum="1" Value="0" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <DockPanel>
                                <TextBlock Text="OUTPUT MAX" FontWeight="Bold" FontSize="10" Foreground="#555555" />
                                <TextBlock x:Name="OutputMaxLabel" FontSize="11" HorizontalAlignment="Right" />
                            </DockPanel>
                            <Slider x:Name="OutputMaxSlider" Minimum="0" Maximum="1" Value="1" />
                        </StackPanel>

                        <!-- Transition width -->
                        <StackPanel Spacing="2">
                            <DockPanel>
                                <TextBlock Text="TRANSITION WIDTH" FontWeight="Bold" FontSize="10" Foreground="#555555" />
                                <TextBlock x:Name="TransitionWidthLabel" FontSize="11" HorizontalAlignment="Right" />
                            </DockPanel>
                            <Slider x:Name="TransitionWidthSlider" Minimum="0" Maximum="0.5" Value="0" />
                        </StackPanel>

                        <!-- Min approach -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="MIN APPROACH" FontWeight="Bold" FontSize="10" Foreground="#555555" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <RadioButton x:Name="MinApproachClampRadio" GroupName="MinApproach"
                                             Content="Clamp" IsChecked="True" />
                                <RadioButton x:Name="MinApproachCutRadio" GroupName="MinApproach"
                                             Content="Cut" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Flat level -->
                        <StackPanel Spacing="2">
                            <DockPanel>
                                <TextBlock Text="FLAT LEVEL" FontWeight="Bold" FontSize="10" Foreground="#555555" />
                                <TextBlock x:Name="FlatLevelLabel" FontSize="11" HorizontalAlignment="Right" />
                            </DockPanel>
                            <Slider x:Name="FlatLevelSlider" Minimum="0" Maximum="1" Value="0.5" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <!-- Splitter -->
            <Rectangle Grid.Column="1" Fill="#CCCCCC" />

            <!-- Right panel: drawing canvas (Skia bitmap-backed) -->
            <Border Grid.Column="2" x:Name="CanvasArea" Background="#F0F0F0" ClipToBounds="True">
                <Image x:Name="DrawImage" Stretch="None"
                       HorizontalAlignment="Left" VerticalAlignment="Top" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
